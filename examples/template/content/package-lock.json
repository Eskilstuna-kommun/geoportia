{
  "name": "${{ values.name }}",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "${{ values.name }}",
      "dependencies": {
        "root": "file:../../.."
      }
    },
    "../../..": {
      "name": "root",
      "version": "1.0.0",
      "hasInstallScript": true,
      "dependencies": {
        "@babel/cli": "^7.23.0",
        "@babel/core": "^7.23.0",
        "@babel/plugin-transform-runtime": "^7.22.15",
        "@babel/preset-env": "^7.22.20",
        "@backstage/repo-tools": "^0.13.3",
        "@mui/icons-material": "^7.3.7",
        "@useoptic/optic": "^1.0.5",
        "geoserver-rest-client": "https://github.com/sweco-se1g7y/geoserver-node-client.git#typescript",
        "pg": "^8.17.2",
        "pg-listen": "^1.7.0"
      },
      "devDependencies": {
        "@backstage/cli": "^0.32.1",
        "@backstage/e2e-test-utils": "^0.1.1",
        "@playwright/test": "^1.32.3",
        "@types/crypto-js": "^4",
        "@types/pg": "^8",
        "cross-env": "^7.0.0",
        "node-gyp": "^10.0.0",
        "prettier": "^2.3.2",
        "typescript": "~5.4.0"
      },
      "engines": {
        "node": "20 || 22"
      },
      "workspaces": {
        "packages": [
          "packages/*",
          "plugins/*"
        ]
      }
    },
    "node_modules/root": {
      "resolved": "../../..",
      "link": true
    }
  }
}
