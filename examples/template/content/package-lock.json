{
  "name": "${{ values.name }}",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "${{ values.name }}",
      "dependencies": {
        "root": "file:../../.."
      }
    },
    "../../..": {
      "name": "root",
      "version": "1.0.0",
      "dependencies": {
        "@backstage/repo-tools": "^0.13.3",
        "@useoptic/optic": "^1.0.5"
      },
      "devDependencies": {
        "@backstage/cli": "^0.32.1",
        "@backstage/e2e-test-utils": "^0.1.1",
        "@playwright/test": "^1.32.3",
        "node-gyp": "^10.0.0",
        "prettier": "^2.3.2",
        "typescript": "~5.4.0"
      },
      "engines": {
        "node": "20 || 22"
      },
      "workspaces": {
        "packages": [
          "packages/*",
          "plugins/*"
        ]
      }
    },
    "node_modules/root": {
      "resolved": "../../..",
      "link": true
    }
  }
}
